<Window x:Class="WindowsCleaner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Cleaner Tool" Height="580" Width="780"
        WindowStartupLocation="CenterScreen"
        Background="#FF1B1B1F" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#FF0A84FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="24,12" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="8" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FF339CFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Background" Value="#FF3A3A42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A31" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#FF3A3A44" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Windows Cleaner Tool" Foreground="White" FontSize="28" FontWeight="SemiBold" />
                <TextBlock x:Name="EnvText" Foreground="#FF9A9AA5" FontSize="12" Margin="0,2,0,0" />
            </StackPanel>
            <Border Grid.Column="1" VerticalAlignment="Top" Background="#FF2A2A31" CornerRadius="8" Padding="12,6">
                <TextBlock x:Name="ScoreText" Text="Ready" Foreground="White" FontWeight="SemiBold" />
            </Border>
        </Grid>

        <!-- Unsupported OS warning -->
        <Border Grid.Row="1" x:Name="SupportBar" Visibility="Collapsed" Margin="0,16,0,0"
                Background="#33FFB020" BorderBrush="#FFFFB020" BorderThickness="1" CornerRadius="8" Padding="12">
            <StackPanel>
                <TextBlock Text="Unsupported Windows version" Foreground="#FFFFD479" FontWeight="SemiBold" />
                <TextBlock x:Name="SupportText" Foreground="#FFE8C98A" TextWrapping="Wrap" FontSize="12" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- One-click clean -->
        <StackPanel Grid.Row="2" Margin="0,28,0,0" HorizontalAlignment="Center">
            <Button x:Name="CleanButton" Style="{StaticResource AccentButton}" Click="OnCleanClick"
                    MinWidth="240" Content="Clean" />
            <ProgressBar x:Name="Busy" IsIndeterminate="True" Visibility="Collapsed" Height="4" Width="240"
                         Margin="0,10,0,0" Foreground="#FF0A84FF" Background="#FF2A2A31" BorderThickness="0" />
            <TextBlock x:Name="StatusText" Margin="0,12,0,0" HorizontalAlignment="Center" TextAlignment="Center"
                       TextWrapping="Wrap" Foreground="#FFB8B8C2" MaxWidth="600"
                       Text="Click Clean and the tool scans and repairs your system automatically." />
        </StackPanel>

        <!-- Advanced details -->
        <Expander Grid.Row="3" x:Name="DetailsExpander" Header="Details (advanced)" Foreground="#FFB8B8C2"
                  Margin="0,20,0,0" VerticalAlignment="Top">
            <Grid Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Button Content="Scan" Click="OnScanClick" Style="{StaticResource FlatButton}" />
                    <Button Content="Select all" Click="OnSelectAllClick" Style="{StaticResource FlatButton}" />
                    <Button x:Name="FixSelectedButton" Content="Fix selected" Click="OnFixSelectedClick"
                            Style="{StaticResource FlatButton}" IsEnabled="False" />
                    <CheckBox x:Name="DryRunCheck" Content="Dry run (preview only)" Foreground="White"
                              VerticalAlignment="Center" Margin="4,0,0,0" />
                </StackPanel>

                <ListView Grid.Row="1" x:Name="IssuesList" SelectionMode="Extended" Margin="0,8,0,0" Height="220"
                          Background="#FF232329" BorderBrush="#FF3A3A42" Foreground="White">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="10" Height="10" Fill="{Binding SeverityBrush}"
                                         VerticalAlignment="Center" Margin="0,0,10,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Description}" Foreground="#FF9A9AA5" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="{Binding ModuleName}" Foreground="#FF7A7A85"
                                           FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Expander>
    </Grid>
</Window>
