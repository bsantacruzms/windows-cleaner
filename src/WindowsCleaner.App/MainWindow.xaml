<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WindowsCleaner.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WindowsCleaner.App"
    Title="Windows Cleaner Tool">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="24" RowSpacing="16">

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
            <TextBlock Text="Windows Health" FontSize="28" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="12,4" VerticalAlignment="Center">
                <TextBlock x:Name="ScoreText" Text="Not scanned" FontSize="16" FontWeight="SemiBold" />
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <Button x:Name="ScanButton" Content="Scan" Click="OnScanClick" Style="{StaticResource AccentButtonStyle}" />
            <Button x:Name="FixButton" Content="Fix selected" Click="OnFixClick" IsEnabled="False" />
            <CheckBox x:Name="DryRunCheck" Content="Dry run (preview only)" VerticalAlignment="Center" />
            <ProgressRing x:Name="Busy" IsActive="False" Width="24" Height="24" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <ListView Grid.Row="2" x:Name="IssuesList" SelectionMode="Multiple"
                  BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" CornerRadius="8">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:IssueRow">
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="8" ColumnSpacing="12">
                        <Border Grid.Column="0" Width="10" Height="10" CornerRadius="5"
                                VerticalAlignment="Center" Background="{x:Bind SeverityBrush}" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{x:Bind Description}" TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{x:Bind ModuleName}" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock Grid.Row="3" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"
                   Text="A System Restore point and registry backups are created before any change." />
    </Grid>
</Window>
