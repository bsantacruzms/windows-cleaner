<Window x:Class="WindowsCleaner.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows Cleaner Tool" Height="740" Width="980"
        MinHeight="580" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        Background="#FF15151A" FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="#FF0A84FF" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="22,10" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#FF339CFF" /></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="b" Property="Background" Value="#FF3A3A42" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Background" Value="#FF2A2A31" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="b" Property="Background" Value="#FF3A3A44" /></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.45" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FindingItem" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="card" Background="#FF23232B" CornerRadius="8" Padding="12" SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="card" Property="Background" Value="#FF2B2B34" /></Trigger>
                            <Trigger Property="IsSelected" Value="True"><Setter TargetName="card" Property="Background" Value="#FF10365E" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="#FF9A9AA5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tb" Padding="18,9" Margin="0,0,6,0" CornerRadius="8" Background="Transparent">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="tb" Property="Background" Value="#FF1E1E24" /></Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tb" Property="Background" Value="#FF23232B" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- App header -->
        <StackPanel Grid.Row="0" Margin="4,0,4,10">
            <TextBlock Text="Windows Cleaner Tool" Foreground="White" FontSize="26" FontWeight="Bold" />
            <TextBlock x:Name="EnvText" Foreground="#FF8A8A96" FontSize="12" Margin="0,2,0,0" />
        </StackPanel>

        <TabControl x:Name="MainTabs" Grid.Row="1" Background="Transparent" BorderThickness="0"
                    SelectionChanged="OnTabChanged">

            <!-- ===================== CLEAN TAB ===================== -->
            <TabItem Header="Clean" Style="{StaticResource DarkTab}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Health score -->
                    <Border Grid.Row="0" HorizontalAlignment="Right" Background="#FF23232B" CornerRadius="10" Padding="18,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="HEALTH" Foreground="#FF6E6E7A" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock x:Name="ScoreText" Text="&#8212;" Foreground="White" FontSize="18" FontWeight="Bold" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Unsupported OS warning -->
                    <Border Grid.Row="1" x:Name="SupportBar" Visibility="Collapsed" Margin="0,10,0,0"
                            Background="#33FFB020" BorderBrush="#FFFFB020" BorderThickness="1" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Unsupported Windows version" Foreground="#FFFFD479" FontWeight="SemiBold" />
                            <TextBlock x:Name="SupportText" Foreground="#FFE8C98A" TextWrapping="Wrap" FontSize="12" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Action bar -->
                    <Border Grid.Row="2" Margin="0,12,0,0" Background="#FF1D1D24" CornerRadius="12" Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="CleanButton" Style="{StaticResource AccentButton}" Click="OnCleanClick" MinWidth="150" Content="Clean" />
                                <StackPanel VerticalAlignment="Center" Margin="14,0,0,0">
                                    <ProgressBar x:Name="Busy" IsIndeterminate="True" Visibility="Collapsed" Width="190" Height="6"
                                                 Foreground="#FF0A84FF" Background="#FF2A2A31" BorderThickness="0" />
                                    <TextBlock x:Name="EtaText" Visibility="Collapsed" Foreground="#FF8A8A96" FontSize="11" Margin="0,4,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="ScanButton" Content="Scan" Click="OnScanClick" Style="{StaticResource FlatButton}" />
                                <Button x:Name="SelectAllButton" Content="Select all" Click="OnSelectAllClick" Style="{StaticResource FlatButton}" />
                                <Button x:Name="FixSelectedButton" Content="Fix selected" Click="OnFixSelectedClick" Style="{StaticResource FlatButton}" IsEnabled="False" />
                                <CheckBox x:Name="DryRunCheck" Content="Dry run" Foreground="#FFB8B8C2" VerticalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Findings -->
                    <Border Grid.Row="3" Margin="0,14,0,0" Background="#FF19191F" CornerRadius="12" Padding="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Findings" Foreground="#FF9A9AA5" FontWeight="SemiBold" FontSize="13" Margin="6,2,6,8" />
                            <ListView Grid.Row="1" x:Name="IssuesList" SelectionMode="Extended"
                                      Background="Transparent" BorderThickness="0" Foreground="White"
                                      ItemContainerStyle="{StaticResource FindingItem}"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="4" CornerRadius="2" Background="{Binding SeverityBrush}" Margin="0,0,12,0" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Description}" Foreground="#FF9A9AA5" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                                <Border Background="{Binding StatusBrush}" CornerRadius="6" Padding="8,3" Margin="0,0,6,0"
                                                        Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                                </Border>
                                                <Border Background="#FF2E2E38" CornerRadius="6" Padding="8,3">
                                                    <TextBlock Text="{Binding ModuleName}" Foreground="#FFB0B0BD" FontSize="11" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- Status -->
                    <TextBlock Grid.Row="4" x:Name="StatusText" Margin="6,12,6,0" Foreground="#FFB8B8C2" TextWrapping="Wrap"
                               Text="Click Clean and the tool scans and repairs your system automatically." />
                </Grid>
            </TabItem>

            <!-- ===================== PRIVACY TAB ===================== -->
            <TabItem x:Name="PrivacyTab" Header="Privacy" Style="{StaticResource DarkTab}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FF1D1D24" CornerRadius="12" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="HardenButton" Content="Apply privacy hardening" Click="OnHardenClick"
                                    Style="{StaticResource AccentButton}" FontSize="15" Padding="18,9" />
                            <TextBlock Grid.Column="1" x:Name="PrivacyStatusText" Foreground="#FF8A8A96" FontSize="12"
                                       VerticalAlignment="Center" Margin="14,0,0,0" TextWrapping="Wrap"
                                       Text="Disables telemetry and tracking. Everything here is reversible." />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="Select all" Click="OnSelectAllPrivacyClick" Style="{StaticResource FlatButton}" />
                                <Button Content="Revert" Click="OnRevertPrivacyClick" Style="{StaticResource FlatButton}" />
                                <Button Content="Refresh" Click="OnRefreshPrivacyClick" Style="{StaticResource FlatButton}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="PrivacyList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF23232B" CornerRadius="10" Padding="14" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Selected, Mode=TwoWay}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Description}" Foreground="#FF9A9AA5" FontSize="12" TextWrapping="Wrap" Margin="0,3,0,0" />
                                            </StackPanel>
                                            <Border Grid.Column="2" Background="{Binding StateBrush}" CornerRadius="6" Padding="8,3"
                                                    VerticalAlignment="Center" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding StateText}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Grid.Row="2" Margin="6,10,6,0" Foreground="#FF6E6E7A" FontSize="11" TextWrapping="Wrap"
                               Text="Tip: sign out or restart for all changes to fully apply. Use Revert to restore Windows defaults." />
                </Grid>
            </TabItem>

            <!-- ===================== DISKS TAB ===================== -->
            <TabItem x:Name="DisksTab" Header="Disks" Style="{StaticResource DarkTab}">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Background="#FF1D1D24" CornerRadius="12" Padding="16,12">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Refresh" Click="OnRefreshDisksClick" Style="{StaticResource FlatButton}" />
                            <Button Content="Open Disk Management" Click="OnOpenDiskMgmtClick" Style="{StaticResource FlatButton}" />
                            <Button Content="Open Disk Cleanup" Click="OnOpenDiskCleanupClick" Style="{StaticResource FlatButton}" />
                            <TextBlock x:Name="DiskStatusText" Foreground="#FF8A8A96" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0"
                                       Text="Read-only analysis. For resize / move / merge, use Disk Management." />
                        </StackPanel>
                    </Border>

                    <!-- Disk cards -->
                    <ScrollViewer Grid.Row="1" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="DisksList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#FF23232B" CornerRadius="10" Padding="16" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" FontSize="15" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding SubInfo}" Foreground="#FF9A9AA5" FontSize="12" Margin="0,2,0,0" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                                    <Button Content="+ New partition" Click="OnCreatePartitionClick" Style="{StaticResource FlatButton}"
                                                            FontSize="11" Padding="10,5" Margin="0,0,8,0"
                                                            Visibility="{Binding CanCreate, Converter={StaticResource BoolToVis}}" />
                                                    <Border Background="{Binding HealthBrush}" CornerRadius="6" Padding="10,4">
                                                        <TextBlock Text="{Binding Health}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding Volumes}" Margin="0,12,0,0">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                                <TextBlock Text="{Binding Header}" Foreground="#FFDADAE2" FontSize="12" FontWeight="SemiBold" />
                                                                <ProgressBar Minimum="0" Maximum="{Binding Max}" Value="{Binding Used}" Height="8" Margin="0,5,0,0"
                                                                             Foreground="{Binding BarBrush}" Background="#FF303039" BorderThickness="0" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding SpaceLabel}" Foreground="#FF9A9AA5" FontSize="11" VerticalAlignment="Center" />
                                                            <Button Grid.Column="2" Content="Manage &#x25BE;" Click="OnManageVolumeClick" Style="{StaticResource FlatButton}"
                                                                    FontSize="11" Padding="10,5" Margin="12,0,0,0" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Grid.Row="2" Margin="6,10,6,0" Foreground="#FF6E6E7A" FontSize="11" TextWrapping="Wrap"
                               Text="Windows Cleaner analyses disks read-only. Advanced partitioning (resize, move, merge, clone) is handled by Windows Disk Management to keep your data safe." />
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="2" Margin="4,12,4,0" HorizontalAlignment="Center" Foreground="#FF6E6E7A" FontSize="11">
            Created by Brian Santacruz&#160;&#160;&#183;&#160;&#160;<Hyperlink NavigateUri="https://briansantacruz.com"
                RequestNavigate="OnOpenWebsite" Foreground="#FF6E9FFF" TextDecorations="None">briansantacruz.com</Hyperlink>
        </TextBlock>
    </Grid>
</Window>
